list_pkgs() {
    msg "Available packages:"
    echo "$PKG_JSON" | jq -r 'keys[]' | sed 's/^/  - /'
}

install_pkg() {
    local pkg=$1
    if ! echo "$PKG_JSON" | jq -e ".\"$pkg\"" >/dev/null; then
        err "Package '$pkg' configuration not found!"
    fi

    msg "Starting installation sequence for '$pkg'..."

    # Pre-install routines
    local pre=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".pre_install // empty")
    if [[ -n "$pre" ]]; then
        inf "Running pre-installation commands..."
        eval "$pre"
    fi

    # Handle gpg keys via url
    local gpg_key=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".url.gpg_key // empty")
    local gpg_dest=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".gpg_dest // empty")
    
    if [[ -n "$gpg_key" && -n "$gpg_dest" ]]; then
        inf "Importing GPG key to $gpg_dest..."
        # If dest is a .gpg we dearmor it, if it's .asc we just save it directly
        sudo mkdir -p $(dirname "$gpg_dest")
        if [[ "$gpg_dest" == *".gpg" ]]; then
            curl -fsSL "$gpg_key" | sudo gpg --dearmor --yes -o "$gpg_dest"
        else
            curl -fsSL "$gpg_key" | sudo tee "$gpg_dest" >/dev/null
        fi
    fi

    # Handle repository
    local repo_line=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".repo_line // empty")
    local repo_dest=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".repo_dest // empty")

    if [[ -n "$repo_line" && -n "$repo_dest" ]]; then
        inf "Adding repository link to $repo_dest..."
        sudo mkdir -p $(dirname "$repo_dest")
        echo -e "$repo_line" | sudo tee "$repo_dest" >/dev/null
        inf "Updating apt cache..."
        sudo apt update -y
    fi

    # Handle apt packages installation
    local apt_pkgs=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".apt_packages[]? // empty")
    if [[ -n "$apt_pkgs" ]]; then
        inf "Installing apt packages: $(echo $apt_pkgs | tr '\n' ' ')..."
        sudo apt update -y
        # Use simple for loop over words as apt inputs
        sudo apt install -y $apt_pkgs
    fi

    # Handle script download and run
    local run_script=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".url.install_script // empty")
    local runner=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".script_runner // empty")
    if [[ -n "$run_script" ]]; then
        [[ -z "$runner" ]] && runner="bash"
        inf "Running external script via ($runner)..."
        curl -fsSL "$run_script" | eval "$runner"
    fi

    # Handle post-install routines
    local post=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".post_install // empty")
    if [[ -n "$post" ]]; then
        inf "Running post-installation commands..."
        eval "$post"
    fi

    msg "Finished installation for '$pkg'."
}

uninstall_pkg() {
    local pkg=$1
    if ! echo "$PKG_JSON" | jq -e ".\"$pkg\"" >/dev/null; then
        err "Package '$pkg' configuration not found!"
    fi

    local uninstall_cmd=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".uninstall // empty")
    
    msg "Starting uninstall sequence for '$pkg'..."
    if [[ -n "$uninstall_cmd" ]]; then
        inf "Running specialized uninstall command..."
        eval "$uninstall_cmd"
    else
        inf "No custom uninstall script found."
        local apt_pkgs=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".apt_packages[]? // empty")
        if [[ -n "$apt_pkgs" ]]; then
            inf "Purging apt packages..."
            sudo apt --purge remove -y $apt_pkgs
            sudo apt autoremove -y
        fi
        
        local repo_dest=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".repo_dest // empty")
        local gpg_dest=$(echo "$PKG_JSON" | jq -r ".\"$pkg\".gpg_dest // empty")
        
        if [[ -n "$repo_dest" ]]; then
            inf "Removing repository..."
            sudo rm -f "$repo_dest"
        fi
        if [[ -n "$gpg_dest" ]]; then
            inf "Removing GPG key..."
            sudo rm -f "$gpg_dest"
        fi
    fi
    msg "Uninstall routine complete for '$pkg'."
}

show_help() {
    out "Usage: $0 [options]"
    out "Options:"
    out "  -i <pkg>   Install <pkg>"
    out "  -r <pkg>   Uninstall <pkg>"
    out "  -l         List available packages"
    out "  -h         Show this help"
}

if [[ $# -eq 0 ]]; then
    show_help
    exit 0
fi

while getopts "i:r:lh" opt; do
    case $opt in
        i)
            install_pkg "$OPTARG"
            ;;
        r)
            uninstall_pkg "$OPTARG"
            ;;
        l)
            list_pkgs
            ;;
        h)
            show_help
            ;;
        *)
            err "Invalid option"
            ;;
    esac
done
