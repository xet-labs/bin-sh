#!/usr/bin/env bash

scriptPath="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
scriptDir="$(dirname "$scriptPath")"
scriptName="${0##*/}"

[ -f "${scriptDir}/libxlvini" ] && source "${scriptDir}/libxlvini"

show_usage() {
    cat <<EOF
Usage: ${scriptName} <options> [binary-name] [binary-arguments...]

Finds and executes the specified binary. If the binary is not found in the
current PATH, it dynamically loads extended paths (via xlvini.profile.sh)
and searches for architecture-specific versions of the binary.

Options:
  -h, --help      Show this help message and exit
  -r, --resolve   Resolve and print the absolute path of the binary instead of executing it
                  (Must be passed before the binary name)

Examples:
  ${scriptName} <binary-name>
  ${scriptName} -r <binary-name>
EOF
}

RESOLVE_PATH_SIG=0

[[ "$1" == "-h" || "$1" == "--help" ]] && { show_usage; exit 0; }
[[ "$1" == "-r" || "$1" == "--resolve" ]] && { RESOLVE_PATH_SIG=1; shift; }
TARGET="$1"; shift

[ -z "$TARGET" ] && { swrn "No target specified!"; show_usage; exit 1; }

# Check if the package binary exists
FOUND_NON_EXEC=0

isBin() {
    local _bin=$1
    #- check if command exists in $PATH
    if command -v "$_bin" &>/dev/null; then
        BINARY="$(command -v "$_bin")"
        return 0
    #- check if command exists in scriptDir
    elif [[ -f "${scriptDir}/$_bin" && -x "${scriptDir}/$_bin" ]]; then
        BINARY="${scriptDir}/$_bin"
        return 0
    #- check if command exists in current directory
    elif [[ -f "./$_bin" && -x "./$_bin" ]]; then
        BINARY="./$_bin"
        return 0
    fi

    #- check if it exists but is not executable to accurately report 126
    if [[ -f "${scriptDir}/$_bin" ]] || [[ -f "./$_bin" ]]; then
        FOUND_NON_EXEC=1
    fi
    return 1
}

# 1. If the binary is in the system, simply use that
if isBin "$TARGET"; then
    : # BINARY is set to the system binary
else
    # 2. If not, import xlvini.profile.sh to build $PATH
    [ -f /etc/profile.d/xlvini.profile.sh ] && source /etc/profile.d/xlvini.profile.sh

    ARCH=$(uname -m)

    anyArch() {
        local arch
        for arch in "$@"; do
            if isBin "${TARGET}.${arch}"; then
                echo "${TARGET}.${arch}"
                return 0
            elif isBin "x${TARGET}.${arch}"; then
                echo "x${TARGET}.${arch}"
                return 0
            fi
        done
        return 1 # none found
    }

    # First check if the plain target is now available in the new PATH
    if isBin "$TARGET"; then
        BINARY_CMD="$TARGET"
    else
        # Check architecture-specific binaries
        case "$ARCH" in
        armv6l | armv7l)
            BINARY_CMD="$(anyArch armv7l)"
            ;;
        armhf)
            BINARY_CMD="$(anyArch arm)"
            ;;
        aarch64 | arm64)
            BINARY_CMD="$(anyArch aarch64 arm64 arm)"
            ;;
        x86)
            BINARY_CMD="$(anyArch x86 aarch64 arm64 arm)"
            ;;
        x86_64 | amd64)
            BINARY_CMD="$(anyArch x86_64 x64 x86 aarch64 arm64 arm)"
            ;;
        *)
            BINARY_CMD="$(anyArch armv7l)"
            ;;
        esac
    fi

    # 3. Validate and set actual path using isBin in the main shell
    if [ -n "$BINARY_CMD" ] && isBin "$BINARY_CMD"; then
        : # BINARY is set to the resolved architecture-specific binary
    else
        if [ "$FOUND_NON_EXEC" -eq 1 ]; then
            swrn "Binary '${TARGET}' found but not executable!!" >&2
            exit 126
        else
            swrn "Binary '${TARGET}' not found!!" >&2
            exit 127
        fi
    fi
fi

# Execute the binary with any passed arguments
[ "$RESOLVE_PATH_SIG" -eq 1 ] && { echo "${BINARY}"; exit 0; }
exec "${BINARY}" "${@}"
